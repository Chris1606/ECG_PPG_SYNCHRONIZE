        </mxCell>
        <mxCell id="sens_ppg_stamp" value="Gán timestamp PPG theo batch&lt;br&gt;batch_time_ms = now - start&lt;br&gt;age_ms = (available - 1 - i) * 10 ms&lt;br&gt;time_ms = batch_time_ms - age_ms" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#e69138;" vertex="1" parent="1">
